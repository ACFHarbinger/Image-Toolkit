{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "sourceMap": false,
    "types": ["chrome"],
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
