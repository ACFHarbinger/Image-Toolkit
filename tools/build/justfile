# tools/build/justfile
# Build recipes for all project components

set shell := ["bash", "-c"]
set unstable := true
set working-directory := '../..'

# Build C++ base extension (pybind11, OpenCV, Eigen3, OpenMP required).
# Replaces the former Rust/maturin build-base (Phase 7: batch/ renamed to base/).
build-base:
    @echo "Building C++ base extension..."
    cmake -B build/base base/ \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_PREFIX_PATH="$(pwd)/opencv/install" \
        -DCMAKE_INSTALL_PREFIX="." \
        && cmake --build build/base -j$(nproc) \
        && cmake --install build/base
    @echo "base extension built and installed."

# Build production application cryptography JAR
build-jar:
    @echo "Building production application cryptography JAR..."
    ./gradlew build

# Build production application frontend
build-frontend:
    @echo "Building production application frontend..."
    npm run build

# Build local OpenCV from source (bypasses system libopencv-dev requirement)
build-opencv:
    @echo "Building local OpenCV source..."
    cmake -B opencv/build opencv/ \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=OFF \
        -DBUILD_TESTS=OFF \
        -DBUILD_PERF_TESTS=OFF \
        -DBUILD_EXAMPLES=OFF \
        -DBUILD_opencv_apps=OFF \
        -DBUILD_opencv_python3=OFF \
        -DCMAKE_INSTALL_PREFIX=opencv/install \
        && cmake --build opencv/build -j$(nproc) \
        && cmake --install opencv/build
    @echo "OpenCV built and installed to opencv/install."

# Build everything: C++ base + Kotlin JAR + TypeScript frontend
build-all: build-base build-jar build-frontend

# Alias for build-all
build: build-all
