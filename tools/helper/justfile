# tools/helper/justfile
# General helper/utility recipes

set shell := ["bash", "-c"]
set unstable := true
set working-directory := '../..'

red := '\033[0;31m'
green := '\033[0;32m'
yellow := '\033[0;33m'
blue := '\033[0;34m'
purple := '\033[0;35m'
cyan := '\033[0;36m'
bold := '\033[1m'
reset := '\033[0m'

# Canonical header — imported by root justfile as helper::_print_header
_print_header:
    @echo -e "{{blue}}╔══════════════════════════════════════════════════════════════════════╗{{reset}}"
    @echo -e "{{blue}}║                        Image Toolkit Control                         ║{{reset}}"
    @echo -e "{{blue}}╚══════════════════════════════════════════════════════════════════════╝{{reset}}"

# Commit staged changes with Gemini as co-author
commit message:
    git commit -m "{{message}}" -m "$(cat .gitmessage)"

# Legacy alias for 'gui' — run Python/PySide6 app directly
python args="":
    @echo "🐍 Starting Python/PySide6 app..."
    source .venv/bin/activate && python main.py {{args}}

